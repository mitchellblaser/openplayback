{
  "name": "openplayback-client",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "react": "^18.0.0",
    "react-arborist": "^3.7.0",
    "react-dom": "^18.0.0",
    "ssh2": "^1.17.0",
    "ws": "^8.20.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^4.0.0",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.js",
  "build": {
